# ── Google Cloud / Vertex AI ──────────────────────────────────────────────────
# Service account key path (local dev) or leave blank if using ADC on Cloud Run
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# ── AI Models ─────────────────────────────────────────────────────────────────
# Standard NPCs (Oswald, Thomas, Agnes, Edgar, Marsh, Hargreaves, Pryce)
MODEL_STANDARD=gemini-3-flash-preview
# Critical NPCs (Cornelia npc_011, Wren npc_012, Clement npc_009, The Voice npc_s03)
MODEL_CRITICAL=gemini-3.1-pro-preview

# Fallback models used on 503/429 after retries are exhausted
MODEL_STANDARD_FALLBACK=gemini-2.5-flash
MODEL_CRITICAL_FALLBACK=gemini-2.5-pro

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://warden:password@localhost:5432/warden_db

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# ── Behaviour ─────────────────────────────────────────────────────────────────
# Maximum tokens per NPC response
MAX_RESPONSE_TOKENS=400
# Seconds before a streaming response times out
RESPONSE_TIMEOUT_SECONDS=8
