# ── Google Cloud / Vertex AI ──────────────────────────────────────────────────
# Service account key path (local dev) or leave blank if using ADC on Cloud Run
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# ── AI Models ─────────────────────────────────────────────────────────────────
# Standard NPCs (Oswald, Thomas, Agnes, Edgar, Marsh, Hargreaves, Pryce)
MODEL_STANDARD=gemini-2.5-flash-preview-05-20
# Critical NPCs (Cornelia, Wren, Clement, The Voice)
MODEL_CRITICAL=gemini-2.5-pro-preview-05-06

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://warden:password@localhost:5432/warden_db

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# ── Behaviour ─────────────────────────────────────────────────────────────────
# Maximum tokens per NPC response
MAX_RESPONSE_TOKENS=400
# Seconds before a streaming response times out
RESPONSE_TIMEOUT_SECONDS=8
